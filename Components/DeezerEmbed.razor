<div class="embed-card">
    <iframe src="@Embed.EmbedUrl"
            title="@($"Deezer player for {ArtistName}")"
            class="embed-frame deezer-frame"
            loading="lazy"
            width="100%"
            height="300"
            allow="encrypted-media; clipboard-write; autoplay; fullscreen; picture-in-picture; accelerometer; gyroscope; 
            allowtransparency="true"></iframe>
    <a href="@Embed.Url"
       target="_blank" 
       rel="noreferrer"
       class="embed-open-link">
        Open in Deezer
    </a>
</div>

@code {
    [Parameter]
    public string ArtistName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public SocialEmbedListItem Embed { get; set; } = default!;
}
