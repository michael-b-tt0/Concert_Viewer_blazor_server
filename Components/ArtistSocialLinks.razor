@inject IHttpClientFactory HttpClientFactory

@if (Embeds.Count > 0 || FallbackLinks.Count > 0)
{
    <div class="artist-socials">
        @if (Embeds.Count > 0)
        {
            @foreach (var embed in Embeds)
            {
                <SocialEmbedHost ArtistName="@ArtistName" Embed="@embed" />
            }
        }

        @if (FallbackLinks.Count > 0)
        {
            <div class="social-link-list">
                @foreach (var socialLink in FallbackLinks)
                {
                    <a href="@socialLink.Url"
                       target="_blank"
                       rel="noreferrer"
                       class="social-link-chip">
                        @SocialLinkResolver.GetDisplayLabel(socialLink)
                    </a>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public string ArtistName { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<SocialLinkListItem> SocialLinks { get; set; } = [];

    private List<SocialEmbedListItem> Embeds { get; set; } = [];
    private List<SocialLinkListItem> FallbackLinks { get; set; } = [];

    protected override async Task OnParametersSetAsync()
    {
        var httpClient = HttpClientFactory.CreateClient("SocialLinks");
        var tempEmbeds = new List<SocialEmbedListItem>();
        var tempFallbacks = new List<SocialLinkListItem>();

        foreach (var link in SocialLinks)
        {
            if (link.Provider == SocialLinkProvider.Bandcamp)
            {
                var embedUrl = await SocialLinkResolver.FetchBandcampEmbedUrlAsync(link.Url, httpClient);
                if (embedUrl != null)
                {
                    tempEmbeds.Add(new SocialEmbedListItem(link.Platform, link.Url, link.Provider, embedUrl));
                }
                else
                {
                    tempFallbacks.Add(link);
                }
            }
            else
            {
                var embed = SocialLinkResolver.TryCreateEmbed(link);
                if (embed != null)
                {
                    tempEmbeds.Add(embed);
                }
                else
                {
                    tempFallbacks.Add(link);
                }
            }
        }

        Embeds = tempEmbeds;
        FallbackLinks = tempFallbacks;
    }
}
