@inherits LayoutComponentBase

<AuthorizeView>
    <Authorized Context="authState">
        <div class="layout-shell">
            <header class="layout-shell__header">
                <div>
                    <p class="layout-shell__eyebrow">Concert Viewer</p>
                    <p class="layout-shell__welcome">Signed in as <strong>@authState.User.Identity?.Name</strong></p>
                </div>

                <div class="layout-shell__actions">
                    <NavLink href="/" Match="NavLinkMatch.All" class="layout-shell__link">Concerts</NavLink>
                    <NavLink href="/concert-scraper" class="layout-shell__link">Scraper</NavLink>
                    <LogoutButton />
                </div>
            </header>

            <main class="layout-shell__body">
                @Body
            </main>
        </div>
    </Authorized>
    <NotAuthorized>
        <LoginPanel />
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
