@page "/"
@rendermode InteractiveServer
@using Concert_Viewer.Data
@using System.Text.Json
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ConcertsContext> DbContextFactory

<PageTitle>Concert Viewer</PageTitle>

<div class="home-shell">
    <section class="hero">
        <p class="eyebrow">Concert Viewer</p>
        <h1>Browse concerts by date</h1>
        <p class="hero-copy">
            Pick a date from <code>canonical_events</code> and review every event scheduled for that day.
        </p>
    </section>

    <section class="toolbar">
        <label class="field" for="event-date">
            <span class="field-label">Event date</span>
            <select id="event-date" class="date-select" value="@selectedDate" @onchange="OnDateChanged" disabled="@isLoadingDates">
                @if (availableDates.Count == 0)
                {
                    <option value="">No dates found</option>
                }
                else
                {
                    @foreach (var date in availableDates)
                    {
                        <option value="@date.Value">@date.Label</option>
                    }
                }
            </select>
        </label>

        <div class="summary-card">
            <span class="summary-label">Events shown</span>
            <strong>@events.Count</strong>
        </div>
    </section>

    @if (loadError is not null)
    {
        <div class="message error-message">@loadError</div>
    }
    else if (isLoadingDates || isLoadingEvents)
    {
        <div class="message loading-message">Loading concert data...</div>
    }
    else if (string.IsNullOrWhiteSpace(selectedDate))
    {
        <div class="message">Select a date to view events.</div>
    }
    else if (events.Count == 0)
    {
        <div class="message">No events were found for @FormatDateLabel(selectedDate).</div>
    }
    else
    {
        <FluentDataGrid TGridItem="EventListItem"
                        Items="@events.AsQueryable()"
                        DisplayMode="DataGridDisplayMode.Table"
                        MultiLine="true"
                        GenerateHeader="GenerateHeaderOption.Sticky"
                        ResizableColumns="true"
                        RowSize="DataGridRowSize.Medium"
                        Class="events-grid">
            <PropertyColumn Property="@(item => item.EventTitle)" Title="Title" Sortable="true" />
            <TemplateColumn Title="Image">
                @if (!string.IsNullOrWhiteSpace(context.ImageUrl))
                {
                    <a href="@context.ImageUrl" target="_blank" rel="noreferrer" class="image-link">
                        <img src="@context.ImageUrl" alt="@context.EventTitle" class="event-image" />
                    </a>
                }
                else
                {
                    <span class="muted-text">No image</span>
                }
            </TemplateColumn>
            <PropertyColumn Property="@(item => item.EventStartTime)" Title="Start" Sortable="true" />
            <PropertyColumn Property="@(item => item.Venue)" Title="Venue" Sortable="true" />
            <TemplateColumn Title="Artists">
                @if (context.Artists.Count == 0)
                {
                    <span class="muted-text">No artists listed</span>
                }
                else
                {
                    <ul class="artist-list">
                        @for (var artistIndex = 0; artistIndex < context.Artists.Count; artistIndex++)
                        {
                            var artist = context.Artists[artistIndex];

                            <li class="@GetArtistCardClass(artistIndex)">
                                <span class="artist-name">@artist.Name</span>
                                @if (!string.IsNullOrWhiteSpace(artist.Tags))
                                {
                                    <span class="artist-tags">@artist.Tags</span>
                                }
                                @if (artist.SocialLinks.Count > 0)
                                {
                                    <ArtistSocialLinks ArtistName="@artist.Name" SocialLinks="@artist.SocialLinks" />
                                }
                            </li>
                        }
                    </ul>
                }
            </TemplateColumn>
        </FluentDataGrid>
    }
</div>

@code {
    private static readonly JsonSerializerOptions SocialLinkJsonOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    private List<DateOption> availableDates = [];
    private List<EventListItem> events = [];
    private string? loadError;
    private string? selectedDate;
    private bool isLoadingDates = true;
    private bool isLoadingEvents;

    protected override async Task OnInitializedAsync()
    {
        await LoadAvailableDatesAsync();
    }

    private async Task LoadAvailableDatesAsync()
    {
        isLoadingDates = true;
        loadError = null;

        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();

            var dates = await db.CanonicalEvents
                .AsNoTracking()
                .Where(e => !string.IsNullOrWhiteSpace(e.EventDate))
                .Select(e => e.EventDate)
                .Distinct()
                .OrderByDescending(date => date)
                .ToListAsync();

            availableDates = dates
                .Select(date => new DateOption(date, FormatDateLabel(date)))
                .ToList();

            selectedDate = availableDates.FirstOrDefault()?.Value;

            if (!string.IsNullOrWhiteSpace(selectedDate))
            {
                await LoadEventsAsync();
            }
        }
        catch (Exception ex)
        {
            loadError = $"Unable to load available dates: {ex.Message}";
        }
        finally
        {
            isLoadingDates = false;
        }
    }

    private async Task OnDateChanged(ChangeEventArgs args)
    {
        selectedDate = args.Value?.ToString();
        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        events = [];
        loadError = null;

        if (string.IsNullOrWhiteSpace(selectedDate))
        {
            return;
        }

        isLoadingEvents = true;

        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();

            var matchedEvents = await db.CanonicalEvents
                .AsNoTracking()
                .Include(e => e.EventArtists)
                .ThenInclude(ea => ea.Artist)
                .Where(e => e.EventDate == selectedDate)
                .OrderBy(e => e.EventStartTime)
                .ThenBy(e => e.EventTitle)
                .ToListAsync();

            events = matchedEvents
                .Select(e => new EventListItem
                {
                    Id = e.Id,
                    EventTitle = e.EventTitle ?? "Untitled event",
                    EventStartTime = string.IsNullOrWhiteSpace(e.EventStartTime) ? "TBA" : e.EventStartTime,
                    Venue = string.IsNullOrWhiteSpace(e.Venue) ? "Venue TBA" : e.Venue,
                    ImageUrl = e.ImageUrl,
                    Artists = FormatArtists(e)
                })
                .ToList();
        }
        catch (Exception ex)
        {
            loadError = $"Unable to load events for {FormatDateLabel(selectedDate)}: {ex.Message}";
        }
        finally
        {
            isLoadingEvents = false;
        }
    }

    private static string FormatDateLabel(string? rawDate)
    {
        return DateOnly.TryParse(rawDate, out var parsedDate)
            ? parsedDate.ToString("dddd, dd MMMM yyyy")
            : rawDate ?? string.Empty;
    }

    private static List<ArtistListItem> FormatArtists(Data.Entities.CanonicalEvent concertEvent)
    {
        var artists = concertEvent.EventArtists
            .OrderBy(ea => ea.BillingPosition ?? int.MaxValue)
            .ThenBy(ea => ea.Artist?.Name)
            .Select(FormatArtistDisplay)
            .Where(display => display is not null)
            .Distinct()
            .Cast<ArtistListItem>()
            .ToList();

        return artists;
    }

    private static ArtistListItem? FormatArtistDisplay(Data.Entities.EventArtist eventArtist)
    {
        var artistName = eventArtist.Artist?.Name;
        var tags = NormalizeTags(eventArtist.Artist?.ArtistTags);

        if (string.IsNullOrWhiteSpace(artistName))
        {
            return null;
        }

        return new ArtistListItem(artistName, tags, ParseSocialLinks(eventArtist.Artist?.SocialLinks));
    }

    private static string? NormalizeTags(string? rawTags)
    {
        if (string.IsNullOrWhiteSpace(rawTags))
        {
            return null;
        }

        var normalized = rawTags.Trim();
        return normalized is "[]" or "[ ]" ? null : normalized;
    }

    private static List<SocialLinkListItem> ParseSocialLinks(string? rawSocialLinks)
    {
        if (string.IsNullOrWhiteSpace(rawSocialLinks))
        {
            return [];
        }

        try
        {
            var parsedLinks = JsonSerializer.Deserialize<List<ArtistSocialLink>>(rawSocialLinks, SocialLinkJsonOptions);
            if (parsedLinks is null)
            {
                return [];
            }

            return parsedLinks
                .Where(link => !string.IsNullOrWhiteSpace(link.Url))
                .Select(link => new SocialLinkListItem(
                    SocialLinkResolver.NormalizePlatform(link.Platform, link.Url),
                    link.Url!.Trim(),
                    SocialLinkResolver.DetectProvider(link.Url)))
                .Where(link => !string.IsNullOrWhiteSpace(link.Platform))
                .Distinct()
                .ToList();
        }
        catch (JsonException)
        {
            return [];
        }
    }

    private static string GetArtistCardClass(int index)
    {
        return $"artist-list-item artist-card-tone-{index % 6}";
    }

    private sealed record DateOption(string Value, string Label);

    private sealed class EventListItem
    {
        public int Id { get; init; }

        public string EventTitle { get; init; } = string.Empty;

        public string? ImageUrl { get; init; }

        public string EventStartTime { get; init; } = string.Empty;

        public string Venue { get; init; } = string.Empty;

        public List<ArtistListItem> Artists { get; init; } = [];
    }

    private sealed record ArtistListItem(string Name, string? Tags, List<SocialLinkListItem> SocialLinks);

    private sealed class ArtistSocialLink
    {
        public string? Platform { get; init; }

        public string? Url { get; init; }
    }
}
