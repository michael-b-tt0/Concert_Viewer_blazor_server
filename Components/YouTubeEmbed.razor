@if (!string.IsNullOrWhiteSpace(VideoId))
{
    <div class="embed-card">
        <div id="@PlayerElementId" class="youtube-player-host">
            <button type="button"
                    class="youtube-facade"
                    style="background-image: url('@ThumbnailUrl');"
                    aria-label="@($"Play YouTube video for {ArtistName}")"
                    @onclick="LoadPlayerAsync">
                <span class="youtube-play-button" aria-hidden="true"></span>
                <span class="youtube-title">@ArtistName</span>
            </button>
        </div>
    </div>
}
else
{
    <div class="embed-card">
        <a href="@Embed.Url" target="_blank" rel="noreferrer" class="embed-open-link">
            Open @Embed.Platform
        </a>
    </div>
}

@code {
    [Parameter]
    public string ArtistName { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public SocialEmbedListItem Embed { get; set; } = default!;

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;

    private string PlayerElementId { get; } = $"youtube-player-{Guid.NewGuid():N}";

    private string? VideoId => TryGetYouTubeVideoId(Embed.EmbedUrl);

    private string? ThumbnailUrl => string.IsNullOrWhiteSpace(VideoId)
        ? null
        : $"https://i.ytimg.com/vi/{VideoId}/hqdefault.jpg";

    private async Task LoadPlayerAsync()
    {
        if (string.IsNullOrWhiteSpace(VideoId))
        {
            return;
        }

        await JSRuntime.InvokeVoidAsync(
            "concertViewerYouTube.loadPlayer",
            PlayerElementId,
            VideoId,
            $"YouTube player for {ArtistName}");
    }

    private static string? TryGetYouTubeVideoId(string? embedUrl)
    {
        if (!Uri.TryCreate(embedUrl, UriKind.Absolute, out var uri) ||
            !uri.Host.Contains("youtube.com", StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        var segments = uri.AbsolutePath
            .Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        return segments.Length >= 2 &&
               string.Equals(segments[0], "embed", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(segments[1], "videoseries", StringComparison.OrdinalIgnoreCase)
            ? segments[1]
            : null;
    }
}
